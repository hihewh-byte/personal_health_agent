# ── PHA server ──────────────────────────────────────────────
PHA_HOST=127.0.0.1
PHA_PORT=8788
# Background supervisor: auto = launchd if installed, else keepalive script
# PHA_USE_LAUNCHD=auto
# Install launchd once: bash scripts/pha_install_launchd.sh install
# Legacy keepalive (when launchd not installed): PHA_ENABLE_KEEPALIVE=1 (default)
# PHA_ENABLE_KEEPALIVE=0
# Run mode: nohup | foreground (dev only)
# PHA_RUN_MODE=nohup
# Startup maintenance mode: 0=async background (recommended), 1=sync blocking
# PHA_STARTUP_MAINTENANCE_SYNC=0
# Default UI language: en (OSS) | zh
# PHA_UI_LANG=en
# LLM reply language default when API omits response_locale (usually follows UI)
# PHA_RESPONSE_LOCALE=en

# ── Ollama (required) ───────────────────────────────────────
OLLAMA_BASE_URL=http://127.0.0.1:11434
# Docker + host Ollama: http://host.docker.internal:11434
# Docker bundled profile: http://ollama:11434

OLLAMA_MODEL=qwen2.5:7b-instruct
OLLAMA_MEDICAL_MODEL=qwen2.5:7b-instruct
LLM_TIMEOUT_SECONDS=120
PHA_AGENT_TIMEOUT_SECONDS=180
LLM_PROBE_TIMEOUT_SECONDS=3

# Optional models (pull via scripts/pull-models.sh)
# PHA_SHADOW_ROUTING_MODEL=qwen2.5:1.5b-instruct
# Global audit uses deepseek-r1:14b when available

# ── Demo / fixture anchor ───────────────────────────────────
# When unset, PHA uses the real OS calendar date.
# PHA_ENV_DEMO_ANCHOR=2026-05-15

# ── Chat / numerics ─────────────────────────────────────────
# PHA_CHAT_BACKGROUND_MAX_CHARS=4000
# PHA_NUMERICS_AUDIT_SCOPE=t0_plus_disclosure
# PHA_NUMERICS_T1_M4_MODE=warn

# ── Loop notify (A Draft PR + C webhook; never auto-merge) ──
# Wired at end of scripts/pha_loop_run_from_e2e.sh after distill.
# PHA_LOOP_NOTIFY=1                 # 0=skip notify step
# PHA_LOOP_NOTIFY_CHANNELS=both     # both | draft-pr | webhook
# PHA_LOOP_NOTIFY_APPLY=0           # 1=actually create Draft PR / POST webhook
# PHA_LOOP_NOTIFY_DRAFT_PR=1        # 0=disable channel A even when channels=both
# PHA_LOOP_NOTIFY_ASSIGNEE=         # optional gh --assignee login
# PHA_LOOP_NOTIFY_BASE=main
# LOOP_NOTIFY_WEBHOOK_URL=          # Feishu/Slack/generic incoming webhook
# LOOP_NOTIFY_WEBHOOK_FORMAT=generic  # generic | feishu | slack
