#!/bin/bash
set -euo pipefail
ROOT="/Users/hwh/Documents/myAgents/personal_health_agent"
PORT="${PHA_PORT:-8787}"
HOST="${PHA_HOST:-127.0.0.1}"
LOG="${PHA_RESTART_LOG:-/tmp/pha-8787.log}"
PY="$ROOT/.venv/bin/python"
export PATH="/opt/homebrew/bin:/usr/local/bin:${PATH}"
export PYTHONPATH="$ROOT"

exec >>/tmp/pha-restart-app.log 2>&1
echo "=== PHA-Restart.app $(date -u +%Y-%m-%dT%H:%M:%SZ) ==="

osascript -e 'display notification "Restarting PHA…" with title "PHA"' || true

if [[ ! -x "$PY" ]]; then
  osascript -e 'display alert "PHA venv missing" message "Run: python3 -m venv .venv && pip install -r requirements.txt"'
  exit 1
fi

if command -v lsof >/dev/null 2>&1; then
  lsof -ti ":${PORT}" 2>/dev/null | xargs kill -9 2>/dev/null || true
fi
sleep 1

cd "$ROOT"
nohup "$PY" -m pha.main >"$LOG" 2>&1 &
echo $! >/tmp/pha-${PORT}.pid

ready=0
for _ in $(seq 1 45); do
  if curl -sf "http://${HOST}:${PORT}/health" >/dev/null 2>&1; then
    ready=1
    break
  fi
  sleep 1
done

if [[ "$ready" -eq 1 ]]; then
  build="$(curl -sf "http://${HOST}:${PORT}/health" | sed -n 's/.*"pha_build":"\([^"]*\)".*/\1/p')"
  open "http://${HOST}:${PORT}/"
  osascript -e "display notification \"PHA ready (${build})\" with title \"PHA Restart\"" || true
else
  osascript -e "display alert \"PHA did not start\" message \"See ${LOG}\""
  exit 1
fi
