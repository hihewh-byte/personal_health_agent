#!/bin/bash
set -euo pipefail
PORT="${PHA_PORT:-8787}"
if command -v lsof >/dev/null 2>&1; then
  lsof -ti ":${PORT}" 2>/dev/null | xargs kill -9 2>/dev/null || true
  osascript -e "display notification \"Stopped port ${PORT}\" with title \"PHA Stop\""
else
  osascript -e 'display alert "lsof not found"'
  exit 1
fi
